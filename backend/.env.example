# KisaanMitra - Environment Variables
# Copy this file as .env and fill in your API keys

# === PRIMARY AI (OLLAMA - Unlimited, Offline Capable) ===
# Set to 'true' to use local Ollama server (RECOMMENDED for hackathon)
USE_OLLAMA=true
# Default: http://localhost:11434 (Ollama default port)
OLLAMA_BASE_URL=http://localhost:11434
# Model name - use: llama3.2, phi4, mistral, etc.
OLLAMA_MODEL=llama3.2

# === FALLBACK AI (Google Gemini) ===
# Only needed if Ollama fails. Get key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# === WEATHER API ===
# Get free key from https://openweathermap.org/api
WEATHER_API_KEY=